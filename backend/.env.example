PORT=8080
ENVIRONMENT=development

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gymhub
DB_DIALECT=mysql

# Email (Nodemailer) for forgot-password OTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_app_password
MAIL_FROM=GymHub <your_email@example.com>

# Forgot-password OTP settings
PASSWORD_RESET_OTP_EXPIRES_MINUTES=5
